                &ldquo;{t.review}&rdquo;
              </p>
              <div className="w-8 h-px mb-4" style={{ background: '#C9A84C' }} />
              <div className="text-sm font-medium" style={{ fontFamily: "'Jost',sans-serif", color: '#2C1810' }}>{t.name}</div>
              <div className="text-xs font-light mt-0.5" style={{ fontFamily: "'Jost',sans-serif", color: '#8B6F5E' }}>{t.role} · {t.location}</div>
            </div>
          ))}
        </div>
      </div>
