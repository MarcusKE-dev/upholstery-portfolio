              style={{ borderColor: 'rgba(201,168,76,0.2)', background: 'rgba(201,168,76,0.03)' }}>
              <span className="absolute top-4 right-5 text-5xl select-none leading-none"
                style={{ fontFamily: "'Cormorant Garamond',serif", color: 'rgba(201,168,76,0.18)' }}>"</span>
              <div className="flex gap-1 mb-5">{Array.from({ length: 5 }).map((_, j) => <span key={j} style={{ color: '#C9A84C', fontSize: 14 }}>★</span>)}</div>
              <p className="flex-1 text-base font-light leading-relaxed mb-8 italic"
