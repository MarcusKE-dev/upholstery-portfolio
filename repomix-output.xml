<file path="app/globals.css">
@tailwind base;
@tailwind components;
@tailwind utilities;

@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Jost:wght@300;400;500;600&display=swap');

:root {
  --cream-50: #FDFAF4;
  --gold: #C9A84C;
  --espresso: #2C1810;
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  background-color: var(--cream-50);
  color: #2D2D2D;
  font-family: 'Jost', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.skeleton {
  background: linear-gradient(90deg, #e8dfd0 25%, #f0e8da 50%, #e8dfd0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.8s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.gold-line {
  width: 48px; height: 1px;
  background: linear-gradient(90deg, transparent, #C9A84C, transparent);
}

.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.project-card img {
  transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.project-card:hover img { transform: scale(1.06); }
.project-card .overlay { opacity: 0; transition: opacity 0.4s ease; }
.project-card:hover .overlay { opacity: 1; }

::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: #FAF5E9; }
::-webkit-scrollbar-thumb { background: #C9A84C; border-radius: 3px; }

@keyframes pulse-ring {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.55); opacity: 0; }
}
.whatsapp-pulse::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: #25d366;
  animation: pulse-ring 2s ease-out infinite;
  z-index: -1;
}

@keyframes fadeUp {
  0% { opacity: 0; transform: translateY(24px); }
  100% { opacity: 1; transform: translateY(0); }
}
.stagger { opacity: 0; animation: fadeUp 0.7s ease forwards; }
</file>

